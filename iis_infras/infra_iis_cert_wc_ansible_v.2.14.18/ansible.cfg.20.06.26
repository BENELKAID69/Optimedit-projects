[defaults]
# Chemin vers ton inventaire par défaut
inventory         = ./inventory.yml

# Chemin vers tes rôles personnalisés
roles_path        = ./roles

# STRATÉGIE DE RECHERCHE DES COLLECTIONS :
# 1. ./collections : Priorité au répertoire local du projet
# 2. /usr/share/ansible/collections : Fallback au système
collections_paths = ./collections:/usr/share/ansible/collections

# Désactivation du check SSH pour gagner du temps et éviter les erreurs interactives
host_key_checking = False

# Gestion des redirections (pour éviter les warnings de redirection vers ansible.windows)
interpreter_python = auto_silent

[privilege_escalation]
# Configuration pour l'exécution Windows
become = False
become_method = runas
become_user = admin_ansible
